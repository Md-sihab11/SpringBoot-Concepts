<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="
         http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <!-- ১. গ্লোবাল প্যারামিটার (ServletContext) - সবাই দেখতে পাবে -->
    <context-param>
        <param-name>db_url</param-name>
        <param-value>jdbc:mysql://localhost:3306/my_db</param-value>
    </context-param>

    <servlet>

        <servlet-name>PaymentServlet</servlet-name>

        <servlet-class>
            com.servlet.contexConfig.Servlett
        </servlet-class>

        <init-param>
            <param-name>merchant_id</param-name>
            <param-value>MID-998877</param-value>
        </init-param>

    </servlet>
    <servlet-mapping>
        <servlet-name>PaymentServlet</servlet-name>
        <url-pattern>/pay</url-pattern>
    </servlet-mapping>
</web-app>